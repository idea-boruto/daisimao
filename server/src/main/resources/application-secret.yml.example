# 复制此文件为 application-secret.yml，填入真实值
# application-secret.yml 已被 .gitignore，不会提交到 git

jwt:
  secret: replace-with-a-256-bit-random-string-at-least-32-chars

spring:
  datasource:
    url: jdbc:mysql://your-db-host:3306/daisimao?useSSL=true&characterEncoding=utf8mb4&serverTimezone=Asia/Shanghai
    username: root
    password: your-db-password
  data:
    redis:
      host: your-redis-host
      port: 6379
      password: your-redis-password
